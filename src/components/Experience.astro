---
import GithubImage from "/img/technologies/github.svg";
import JavaScriptImage from "/img/technologies/javascript.svg";
import MongoDBImage from "/img/technologies/mongodb.svg";
import NodeJSImage from "/img/technologies/nodejs.svg";
import ReactImage from "/img/technologies/react.svg";
import TypeScriptImage from "/img/technologies/typescript.svg";
import HTMLImage from "/img/technologies/html.svg";

import Section from "./Section.astro";

const technologies = [
  {
    id: 1,
    name: "HTML",
    image: HTMLImage,
    style: "shadow-orange-500",
  },
  {
    id: 2,
    name: "JavaScript",
    image: JavaScriptImage,
    style: "shadow-yellow-500",
  },
  {
    id: 3,
    name: "TypeScript",
    image: TypeScriptImage,
    style: "shadow-blue-500",
  },
  {
    id: 4,
    name: "NodeJS",
    image: NodeJSImage,
    style: "shadow-green-500",
  },
  {
    id: 5,
    name: "React",
    image: ReactImage,
    style: "shadow-blue-300",
  },
  {
    id: 6,
    name: "MongoDB",
    image: MongoDBImage,
    style: "shadow-green-500",
  },
  {
    id: 7,
    name: "Github",
    image: GithubImage,
    style: "shadow-black",
  },
];
---

<Section id="experience" class="bg-opacity-50 bg-gray-500 w-full md:h-screen">
  <div
    class="max-w-screen-lg mx-auto p-4 flex flex-col justify-center w-full h-full text-white"
  >
    <div>
      <p class="text-4xl font-bold border-b-4 border-white p-2 inline">
        Tecnologías
      </p>
      <p class="py-6 font-bold">
        Estas son las tecnologías con las que me siento cómodo trabajando.
      </p>
    </div>

    <div
      class="w-full grid grid-cols-2 sm:grid-cols-3 gap-8 text-center py-8 px-12 sm:px-0"
    >
      {
        technologies.map(({ id, style, image, name }) => {
          return (
            <article
              id={`tech-${id}`}
              class={`shadow-md hover:scale-105 duration-500 py-2 rounded-lg text-gray-500 bg-white bg-opacity-50 ${style}`}
            >
              <img src={image} alt={name + " logo"} class="w-20 mx-auto" />
              <p class="mt-4">{name}</p>
            </article>
          );
        })
      }
    </div>
  </div>
</Section>
